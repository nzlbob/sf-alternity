<form class="{{cssClass}} flexcol" autocomplete="off">

    {{!-- Item Sheet Header --}}
    <header class="sheet-header flexrow">
        <img class="profile" src="{{item.img}}" title="{{item.name}}" data-edit="img"/>

        <div class="header-details flexrow">
            <h1 class="charname">
                <input name="name" type="text" value="{{item.name}}" placeholder="{{ localize "SFRPG.ItemSheet.Header.ItemName" }}"/>
            </h1>

            <div class="item-subtitle">
                <h4 class="item-type">{{itemType}}</h4>
                <span class="item-status">{{itemStatus}}</span>
            </div>

            <ul class="summary">
                <li>
                    <input type="text" name="system.requirements" value="{{itemData.requirements}}" placeholder="{{ localize "SFRPG.ItemSheet.Header.Requirements" }}"/>
                </li>
                <li>
                    <input type="text" name="system.source" value="{{itemData.source}}" placeholder="{{ localize "SFRPG.ItemSheet.Header.Source" }}"/>
                </li>
            </ul>
        </div>
    </header>

    {{!-- Item Sheet Navigation --}}
    <nav class="sheet-navigation tabs" data-group="primary">
        <a class="item active" data-tab="description">{{ localize "SFRPG.Description" }}</a>
        <a class="item" data-tab="details">{{ localize "SFRPG.Details" }}</a>
        <a class="item" data-tab="modifiers">{{ localize "SFRPG.Modifiers" }}</a>
    </nav>

    {{!-- Item Sheet Body --}}
    <section class="sheet-body">
        {{!-- Description Tab --}}
        {{> "systems/sfrpg/templates/items/parts/item-description.hbs"}}

        {{!-- Details Tab --}}
        <div class="tab details" data-group="primary" data-tab="details">

            <div class="bubble">
                <h3 class="bubble-header">{{localize "SFA.Archetypes.PowerSettings.Header"}}</h3>

                <div class="bubble-info">
                    <div class="form-group">
                        <label>{{localize "SFA.Archetypes.PowerSettings.FXFactor.Label"}}</label>
                        <div class="form-fields">
                            <input type="number" name="flags.sf-alternity.archetypes.fxPowerFactor" value="{{item.flags.sf-alternity.archetypes.fxPowerFactor}}" min="0" step="0.1" data-dtype="Number" />
                        </div>
                        <p class="notes">{{localize "SFA.Archetypes.PowerSettings.FXFactor.Hint"}}</p>
                    </div>

                    <div class="form-group">
                        <label>{{localize "SFA.Archetypes.PowerSettings.PsionicFactor.Label"}}</label>
                        <div class="form-fields">
                            <input type="number" name="flags.sf-alternity.archetypes.psionicPowerFactor" value="{{item.flags.sf-alternity.archetypes.psionicPowerFactor}}" min="0" step="0.1" data-dtype="Number" />
                        </div>
                        <p class="notes">{{localize "SFA.Archetypes.PowerSettings.PsionicFactor.Hint"}}</p>
                    </div>

                    <div class="form-group">
                        <label>{{localize "SFA.Archetypes.PowerSettings.FXCost.Label"}}</label>
                        <div class="form-fields">
                            <input type="number" name="flags.sf-alternity.archetypes.fxTalentSkillPointCost" value="{{item.flags.sf-alternity.archetypes.fxTalentSkillPointCost}}" min="0" step="1" data-dtype="Number" />
                        </div>
                        <p class="notes">{{localize "SFA.Archetypes.PowerSettings.FXCost.Hint"}}</p>
                    </div>

                    <div class="form-group">
                        <label>{{localize "SFA.Archetypes.PowerSettings.PsionicCost.Label"}}</label>
                        <div class="form-fields">
                            <input type="number" name="flags.sf-alternity.archetypes.psionicTalentSkillPointCost" value="{{item.flags.sf-alternity.archetypes.psionicTalentSkillPointCost}}" min="0" step="1" data-dtype="Number" />
                        </div>
                        <p class="notes">{{localize "SFA.Archetypes.PowerSettings.PsionicCost.Hint"}}</p>
                        <p class="notes"> </p>
                        <p class="notes"> Psionic attack rolls are modified by the characters Spell Weapon Skill Ranks</p>
                    </div>
                </div>
            </div>
            
        </div>

        {{!-- Modifiers Tab --}}
        {{> "systems/sfrpg/templates/items/parts/item-modifiers.hbs"}}
    </section>
</form>
